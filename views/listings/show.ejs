<% layout('/layouts/boilerplate') -%>

<div class="row">
    <div class="col-8 offset-3 mt-3">
        <h3>Rental Details</h3>
    </div>
    <div class="card col-6 offset-3 mt-1">
        <img src="<%= specificListing.image %>" class="card-img-top show-img" alt="property_image">
        <div class="card-body">
            <h5 class="card-text mt-3">
                <%= specificListing.title %>
            </h5>
            <p class="card-text mt-1">
                <%= specificListing.description %> <br/> <br/>
                &#8377; <%= specificListing.price.toLocaleString("en-IN") %> <br/>
                <%= specificListing.location %><b>,</b> 
                <%= specificListing.country %>
            </p>
        </div>
    </div>
    <div class="btns">
        <a href="/listings/<%= specificListing._id %>/edit" 
        class="btn btn-dark all-btns col-2 col-md-1 offset-3">
            Edit 
        </a>
        <form method="post" action="/listings/<%= specificListing._id %>?_method=DELETE">
            <button class="btn btn-dark offset-5">Delete</button>
        </form>
    </div>
</div>